<%layout("/layout/boilerplate")%>

<div class="row mt-4">
    <div class="col-lg-6 offset-lg-3">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4 text-center">
                <p class="text-uppercase text-muted mb-2">Something needs attention</p>
                <h2 class="mb-2"><%= err.statusCode || 500 %></h2>
                <p class="mb-4"><%= err.message || "Something went wrong." %></p>
                <div class="d-flex justify-content-center gap-2 flex-wrap">
                    <a href="/listing" class="btn add-btn text-white">Back to listings</a>
                    <a href="javascript:history.back()" class="btn btn-outline-dark">Go back</a>
                </div>
            </div>
        </div>
    </div>
</div>
