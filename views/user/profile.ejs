<%- layout("/layout/boilerplate") %>
<%
    const formatDate = (dateValue) => new Date(dateValue).toLocaleDateString("en-IN", {
        timeZone: "UTC",
        day: "numeric",
        month: "short",
        year: "numeric",
    });
%>

<section class="profile-shell">
    <div class="profile-hero">
        <div class="profile-hero-copy">
            <p class="profile-kicker mb-2">My profile</p>
            <h2 class="justify-content-start mb-2">Welcome back, <%= currUser.username %></h2>
            <p class="text-muted mb-0">
                Manage your trips, check your cart, and keep a quick eye on your hosting activity from here.
            </p>
        </div>

        <div class="profile-badge-card">
            <span class="profile-badge-label">Account email</span>
            <strong class="profile-badge-value"><%= currUser.email %></strong>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="profile-stat-card">
                <span class="profile-stat-label">Confirmed bookings</span>
                <strong class="profile-stat-value"><%= profileStats.confirmedBookings %></strong>
            </div>
        </div>
        <div class="col-md-4">
            <div class="profile-stat-card">
                <span class="profile-stat-label">Cart items</span>
                <strong class="profile-stat-value"><%= profileStats.cartItems %></strong>
            </div>
        </div>
        <div class="col-md-4">
            <div class="profile-stat-card">
                <span class="profile-stat-label">Hosted listings</span>
                <strong class="profile-stat-value"><%= profileStats.hostedListings %></strong>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="profile-panel">
                <h4 class="mb-3">Quick actions</h4>
                <div class="d-grid gap-2">
                    <a href="/bookings" class="btn add-btn text-white">View my bookings</a>
                    <a href="/cart" class="btn btn-outline-dark">Open cart</a>
                    <a href="/listing/new" class="btn btn-outline-dark">Create listing</a>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="profile-panel">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                    <h4 class="mb-0">Recent bookings</h4>
                    <a href="/bookings" class="profile-inline-link">See all</a>
                </div>

                <% if (!recentBookings.length) { %>
                    <div class="empty-state">
                        <h4>No bookings yet</h4>
                        <p class="text-muted mb-0">Your confirmed trips will appear here after checkout.</p>
                    </div>
                <% } else { %>
                    <% for (let booking of recentBookings) { %>
                        <div class="profile-booking-row">
                            <div>
                                <h5 class="mb-1"><%= booking.title %></h5>
                                <p class="text-muted mb-1"><%= booking.location %></p>
                                <small class="text-muted"><%= formatDate(booking.checkIn) %> to <%= formatDate(booking.checkOut) %></small>
                            </div>
                            <div class="text-lg-end">
                                <strong>&#8377;<%= Number(booking.totalAmount).toLocaleString("en-IN") %></strong>
                                <div class="small text-muted"><%= booking.nights %> night stay</div>
                            </div>
                        </div>
                    <% } %>
                <% } %>
            </div>
        </div>
    </div>
</section>
